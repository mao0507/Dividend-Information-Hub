# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/dividend_hub"

# JWT secrets
JWT_SECRET="change-me"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

PORT=3000
FRONTEND_URL="http://localhost:5174"

# ── Data Sync ──────────────────────────────────────────────
# Set to "true" to enable scheduled data sync (production)
SYNC_ENABLED=false

# Cron expression for daily price sync (default: weekdays 15:30 Asia/Taipei)
SYNC_CRON="30 15 * * 1-5"

# FinMind API token (optional — increases rate limit from 100 to higher tier)
# Register at https://finmindtrade.com/
FINMIND_TOKEN=
